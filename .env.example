CORPUS_DB_PATH=/absolute/path/to/corpus.sqlite
UNIT_TEXT_DB_PATH=/absolute/path/to/unit_text.sqlite
SEMANTIC_INDEX_DB_PATH=/absolute/path/to/semantic_index.sqlite
OPENAI_API_KEY=
